# Security defaults for assets
Options -Indexes

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Izinkan social media crawler (Facebook, Twitter, Discord, dll.)
    # mengakses gambar OG dan asset lain untuk preview yang valid.
    Header always set Access-Control-Allow-Origin "*"

    # Cache-Control untuk aset statis
    <FilesMatch "\.(png|jpg|jpeg|webp|gif|svg|ico|css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

<FilesMatch "(\.env|\.git|\.htaccess|\.htpasswd|\.sql|\.log|config\.php|cookies\.txt|auth\.php|db\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>