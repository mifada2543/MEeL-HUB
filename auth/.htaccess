# Security defaults for auth
Options -Indexes
DirectoryIndex index.php index.html

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<FilesMatch "^(cookies\.txt|config\.php|.*\.sql|.*\.log|activity_logger\.php|auth\.php|db\.php)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>