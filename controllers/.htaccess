# Deny all web access — PHP include-only files
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Izinkan file yang benar-benar ada (API endpoint seperti post_encode.php),
    # blokir sisanya (termasuk redirect loop /err/err/err/...).
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ - [F]
</IfModule>

<IfModule !mod_rewrite.c>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
