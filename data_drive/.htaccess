# =================================================================

# MEeL Cloud Storage Security - Google Drive Mode

# =================================================================

# 1. Matikan mesin eksekusi PHP untuk semua versi (mod_php)

<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# 2. Amankan penanganan handler CGI / FastCGI jika LAMPP menggunakan PHP-FPM

<FilesMatch "\.(php|php3|php4|php5|phtml|phps|pl|py|jsp|asp|sh|cgi|bat|cmd)$">
SetHandler default-handler
RemoveHandler .php .php3 .php4 .php5 .phtml .pl .py .jsp .asp .sh .cgi
RemoveType .php .php3 .php4 .php5 .phtml .pl .py .jsp .asp .sh .cgi
</FilesMatch>

# 3. Proteksi MIME-Type: Paksa file berbahaya menjadi plain text atau download biner

# Ini mencegah browser mengeksekusi HTML/JS tersembunyi (XSS via upload)

ForceType application/octet-stream
<FilesMatch "(?i)\.(php|phtml|pl|py|sh|cgi|exe|bat|cmd|html|htm|js)$">
ForceType text/plain
</FilesMatch>

# 4. Kembalikan file media dan dokumen standar agar bisa dibaca/di-stream normal oleh browser

<FilesMatch "(?i)\.(mp3|mp4|webm|mkv|opus|ogg|wav|jpg|jpeg|png|gif|webp|pdf|txt)$">
ForceType inherit
</FilesMatch>

# 5. Matikan Directory Listing (Mencegah intip struktur folder)

Options -Indexes
